        {"name": "email", "type": "email"},
        {"name": "address", "type": "text", "options": {"max": 500}},
        {"name": "photo", "type": "file", "options": {"maxSize": 5242880, "mimeTypes": ["image/jpeg", "image/png", "image/webp"], "maxSelect": 1}},
        {"name": "id_number", "type": "text", "options": {"max": 50}},
