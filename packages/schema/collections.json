        {"name": "confirmation_date", "type": "date"},
        {"name": "confirmation_id", "type": "relation", "options": {"collectionId": "sacrament_confirmation", "cascadeDelete": false, "maxSelect": 1}},
        {"name": "marriage_date", "type": "date"},
