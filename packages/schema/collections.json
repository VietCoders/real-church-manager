        {"name": "funeral_id", "type": "relation", "options": {"collectionId": "sacrament_funeral", "cascadeDelete": false, "maxSelect": 1}},
        {"name": "notes", "type": "editor"},
        {"name": "tags", "type": "json"},
        {"name": "status", "type": "select", "required": true, "options": {"maxSelect": 1, "values": ["active", "moved_out", "deceased", "excommunicated"]}},
        {"name": "deleted_at", "type": "date"}
