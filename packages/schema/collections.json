      "viewRule": "@request.auth.id != \"\"",
      "createRule": "@request.auth.role ?~ \"priest_\" || @request.auth.role = \"secretary\"",
      "updateRule": "@request.auth.role ?~ \"priest_\" || @request.auth.role = \"secretary\"",
      "deleteRule": "@request.auth.role = \"priest_pastor\""
